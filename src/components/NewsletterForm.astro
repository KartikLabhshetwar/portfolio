---
interface Props { title?: string; blurb?: string; }
const { title = 'Newsletter', blurb = 'I share what I learn.' } = Astro.props;
const substackUrl = 'https://kartiklabhshetwar.substack.com';
---
<section class="mt-12 rounded-lg border border-black/10 p-5 dark:border-white/10">
  <h2 class="font-semibold">{title}</h2>
  <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
    {blurb}
  </p>
  <div class="mt-3 flex flex-wrap gap-2">
    <a
      href={substackUrl}
      target="_blank"
      rel="noopener"
      class="rounded-md bg-zinc-900 px-4 py-2 text-sm text-white dark:bg-white dark:text-zinc-900"
    >
      Subscribe on Substack
    </a>
    <a
      href={substackUrl}
      target="_blank"
      rel="noopener"
      class="rounded-md border border-black/15 px-4 py-2 text-sm dark:border-white/15"
    >
      Read on Substack
    </a>
  </div>
</section>
