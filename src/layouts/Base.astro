---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import VisitorCount from '../components/VisitorCount.astro';
import CommandMenu from '../components/CommandMenu.tsx';
import { FooterBrand } from '../components/name-brand';
import { profile } from '../data/profile';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';
const { title = 'Kartik Labhshetwar', description = 'Developer, builder.' } = Astro.props;
// Always point canonical at the configured production domain (Astro.site),
// so a workers.dev or any mirror host can't compete for ranking.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.href;
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const commandItems = [
  { label: 'Home', href: '/', group: 'Pages' },
  { label: 'Projects', href: '/projects', group: 'Pages' },
  { label: 'Blog', href: '/blog', group: 'Pages' },
  { label: 'Sponsors', href: '/sponsors', group: 'Pages' },
  ...projects.map((p) => ({
    label: p.title,
    href: p.liveLink ?? p.githubLink ?? '/projects',
    group: 'Projects',
    external: true,
    keywords: [p.description, p.impact].filter(Boolean) as string[],
  })),
  ...posts.map((p) => ({
    label: p.data.title,
    href: `/blog/${p.id.replace(/\/index$/, '')}`,
    group: 'Writing',
    keywords: [p.data.description],
  })),
  ...profile.socials.map((s) => ({ label: s.label, href: s.href, group: 'Links', external: true })),
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const t = localStorage.getItem('theme');
      const dark = t ? t === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', dark);
    </script>
    <script defer src="https://cdn.databuddy.cc/databuddy.js"></script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <main class="mx-auto max-w-2xl px-4">
      <Nav />
      <slot />
      <footer class="mt-24 border-t border-black/10 pt-3 dark:border-white/10">
        <div class="flex justify-end pb-1"><VisitorCount /></div>
        <div class="-mx-4 aspect-[22/1] overflow-hidden text-foreground">
          <FooterBrand client:visible />
        </div>
      </footer>
    </main>
    <CommandMenu client:idle items={commandItems} />
  </body>
</html>
