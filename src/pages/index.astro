---
import Base from '../layouts/Base.astro';
import { HeroTagline } from '../components/HeroTagline';
import { WorkExperience } from '../components/work-experience';
import HomeProjects from '../components/HomeProjects.astro';
import HomeSponsors from '../components/HomeSponsors.astro';
import BlogCard from '../components/BlogCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { profile } from '../data/profile';
import { experience } from '../data/experience';
import { getCollection } from 'astro:content';

const toSlug = (id: string) => id.replace(/\/index$/, '');
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 3);
---
<Base>
  <section class="py-10">
    <div class="flex flex-col items-start gap-5 sm:flex-row sm:items-center sm:gap-8">
      <img
        src="/kartik.png"
        alt={profile.name}
        class="size-24 shrink-0 rounded-full object-cover ring-2 ring-border sm:size-33"
      />
      <div>
        <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{profile.name}</h1>
        <p class="mt-2"><HeroTagline client:visible /></p>
      </div>
    </div>
    <p class="mt-5 max-w-prose text-sm leading-relaxed text-foreground/75">{profile.bio}</p>
    <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1 text-sm">
      {profile.socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="text-muted-foreground underline-offset-4 hover:text-foreground hover:underline">{s.label}</a>
      ))}
    </div>
  </section>

  <section class="-mx-6 border-t border-border px-6 py-10">
    <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Experience</h2>
    <div class="mt-2">
      <WorkExperience client:visible experiences={experience} className="px-0 bg-transparent" />
    </div>
  </section>

  <section class="-mx-6 border-t border-border px-6 py-10">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Projects</h2>
      <a href="/projects" class="text-xs text-muted-foreground hover:text-foreground">All →</a>
    </div>
    <HomeProjects server:defer />
  </section>

  <section class="-mx-6 border-t border-border px-6 py-10">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Writing</h2>
      <a href="/blog" class="text-xs text-muted-foreground hover:text-foreground">All →</a>
    </div>
    <div class="mt-1">{posts.map((p) => <BlogCard title={p.data.title} description={p.data.description} pubDate={p.data.pubDate} slug={toSlug(p.id)} />)}</div>
  </section>
  <section class="-mx-6 border-t border-border px-6 py-10">
    <HomeSponsors server:defer />
  </section>
  <section class="-mx-6 border-t border-border px-6 py-10">
    <NewsletterForm />
  </section>
</Base>
