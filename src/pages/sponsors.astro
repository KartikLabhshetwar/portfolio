---
export const prerender = false;
import Base from '../layouts/Base.astro';
import SponsorCard from '../components/SponsorCard.astro';
import { fetchSponsors, resolveGithubToken } from '../lib/github';
// Fetch at request time so the runtime GITHUB_TOKEN Worker secret is used (the
// prerendered build has no token). Cache the result at the edge for an hour.
const sponsors = await fetchSponsors(await resolveGithubToken());
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=3600');
const recurring = sponsors.filter((s) => !s.isOneTime);
const oneTime = sponsors.filter((s) => s.isOneTime);
const sponsorUrl = 'https://github.com/sponsors/KartikLabhshetwar';
---
<Base title="Sponsors — Kartik Labhshetwar">
  <h1 class="text-2xl font-semibold tracking-tight">Sponsors</h1>
  <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
    Thank you to everyone who supports my work.
    <a href={sponsorUrl} target="_blank" rel="noopener noreferrer" class="underline underline-offset-4">Become a sponsor ↗</a>
  </p>

  {sponsors.length === 0 && (
    <p class="mt-8 text-sm text-zinc-500">Be the first to sponsor.</p>
  )}

  {recurring.length > 0 && (
    <section class="mt-8">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Recurring</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">{recurring.map((s) => <SponsorCard {...s} />)}</div>
    </section>
  )}

  {oneTime.length > 0 && (
    <section class="mt-8">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-zinc-500">One-time</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2">{oneTime.map((s) => <SponsorCard {...s} />)}</div>
    </section>
  )}
</Base>
