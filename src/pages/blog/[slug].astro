---
import Base from '../../layouts/Base.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { TOCMinimap } from '../../components/toc-minimap';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\/index$/, '') },
    props: { post },
  }));
}
const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocItems = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({ title: h.text, url: `#${h.slug}`, depth: h.depth }));
const date = post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`${post.data.title} — Kartik Labhshetwar`} description={post.data.description}>
  {tocItems.length > 1 && (
    <nav aria-label="On this page" class="fixed top-1/2 right-6 z-40 hidden -translate-y-1/2 xl:block">
      <TOCMinimap client:visible items={tocItems} />
    </nav>
  )}
  <a href="/blog" class="mt-6 inline-block text-xs text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-50">← Blog</a>
  <article class="mt-4">
    <header class="border-b border-black/10 pb-6 dark:border-white/10">
      <h1 class="text-2xl font-semibold tracking-tight">{post.data.title}</h1>
      <p class="mt-2 text-xs text-zinc-500"><time datetime={post.data.pubDate.toISOString()}>{date}</time></p>
    </header>
    <div class="prose prose-zinc dark:prose-invert font-serif mt-8 max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-pre:text-xs prose-img:rounded-lg">
      <Content />
    </div>
  </article>
  <NewsletterForm title="Enjoyed this post?" blurb="Get new posts and what I'm learning, in your inbox." />
</Base>
